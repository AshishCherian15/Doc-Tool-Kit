# Database (required on Vercel — use Neon, Vercel Postgres, or Supabase)
# Example Neon: postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/doc_tool_kit?schema=public"

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Storage
MAX_FILE_SIZE=52428800
